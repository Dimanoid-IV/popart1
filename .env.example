# Скопируйте в .env.local и подставьте значения.
# Секреты в Git не хранятся — см. SETUP_NEW_MACHINE.md

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=orders@popart.ee
ADMIN_EMAIL=your@email.com

# Платежи (Stripe) — для локальной разработки используйте sk_test_...
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Генерация изображений
NANOBANANA_API_KEY=xxxxxxxx

# Опционально: хостинг изображений
IMGBB_API_KEY=xxxxxxxx

# RankBoost → PopArt blog publishing webhook
# Один и тот же секрет нужно указать в RankBoost Custom Webhook settings.
RANKBOOST_WEBHOOK_SECRET=replace-with-long-random-secret

# GitHub token с правом Contents: Read and write только для репозитория popart1.
# Endpoint коммитит новую статью в src/data/blog/{locale}/{slug}.json.
POPART_GITHUB_TOKEN=github_pat_xxxxxxxx
POPART_GITHUB_OWNER=Dimanoid-IV
POPART_GITHUB_REPO=popart1
POPART_GITHUB_BRANCH=main
